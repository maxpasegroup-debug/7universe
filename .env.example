# Prisma / PostgreSQL (Railway)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# App URL (used for referral links; browser falls back to window.location.origin)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Admin panel
ADMIN_PASSWORD=change-me-strong
ADMIN_JWT_SECRET=min-32-chars-random-secret-string
