# Prisma / PostgreSQL (Supabase: Project Settings → Database → Connection string URI)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# App URL (used for referral links; browser falls back to window.location.origin)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: service role key (never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin panel (JWT session cookie)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong
ADMIN_JWT_SECRET=min-32-chars-random-secret-string

# Cron (Vercel Cron hits GET /api/cron/reminders with this header)
CRON_SECRET=random-secret-for-cron
INACTIVITY_REMINDER_DAYS=4

# WhatsApp Cloud API (Meta) — optional; messages skipped if unset
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_MSG_WELCOME=
WHATSAPP_MSG_REMINDER=
WHATSAPP_MSG_EXPERT=
